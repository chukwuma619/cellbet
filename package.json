{
  "name": "cellbet",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:frontend": "pnpm --filter @cellbet/frontend dev",
    "dev:backend": "pnpm --filter @cellbet/backend dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "test": "pnpm --filter @cellbet/backend test"
  },
  "packageManager": "pnpm@9.15.9",
  "pnpm": {
    "ignoredBuiltDependencies": ["sharp", "unrs-resolver"]
  }
}
