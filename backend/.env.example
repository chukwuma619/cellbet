# Neon Postgres — copy to backend/.env and fill from https://console.neon.tech
DATABASE_URL=

# API port (use 3001 if Next.js uses 3000)
# PORT=3001

# Comma-separated origins for CORS + Socket.IO (browser clients)
# CORS_ORIGIN=http://localhost:3000

# Crash round tuning (optional)
# CRASH_BETTING_SECONDS=10
# CRASH_TICK_MS=50
# CRASH_LOCK_MS=800
# CRASH_MIN_BET=1
# CRASH_MAX_BET=100000
# Fee on gross cash-out (stake × multiplier), in basis points: 300 = 3%
# CRASH_CASHOUT_FEE_BPS=300

# On-chain CKB (must match frontend NEXT_PUBLIC_CKB_NETWORK / RPC)
# CKB_NETWORK=testnet
# CKB_RPC_URL=

# Crash `crash-round` script (same values as frontend NEXT_PUBLIC_* without prefix)
# CRASH_ROUND_TYPE_SCRIPT_CODE_HASH=0x...
# CRASH_ROUND_TYPE_SCRIPT_HASH_TYPE=data1
# CRASH_ROUND_SCRIPT_CELL_DEP_TX_HASH=0x...
# CRASH_ROUND_SCRIPT_CELL_DEP_INDEX=0
# CRASH_ROUND_SCRIPT_CELL_DEP_TYPE=code

# House hot wallet (must match escrow lock on mint txs) + platform payout address
# HOUSE_CKB_PRIVATE_KEY=0x...   # 32-byte secp256k1 hex — server only, never expose to client
# PLATFORM_CKB_ADDRESS=ckt1...
