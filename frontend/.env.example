# CKB — must match the wallet network (ccc.Provider uses public testnet by default).
# testnet | mainnet | devnet
NEXT_PUBLIC_CKB_NETWORK=testnet

# Optional: override RPC (local devnet, private node, or https://testnet.ckb.dev)
# NEXT_PUBLIC_CKB_RPC_URL=

# Optional: explorer base (defaults to explorer.nervos.org / testnet.explorer.nervos.org)
# NEXT_PUBLIC_CKB_EXPLORER_BASE=

# Crash — crash-round script + house/platform (deploy contracts/crash-round and set all of these)
# NEXT_PUBLIC_CRASH_ROUND_TYPE_SCRIPT_CODE_HASH=0x...
# NEXT_PUBLIC_CRASH_ROUND_TYPE_SCRIPT_HASH_TYPE=data1
# NEXT_PUBLIC_CRASH_ROUND_SCRIPT_CELL_DEP_TX_HASH=0x...
# NEXT_PUBLIC_CRASH_ROUND_SCRIPT_CELL_DEP_INDEX=0
# NEXT_PUBLIC_CRASH_ROUND_SCRIPT_CELL_DEP_TYPE=code
# NEXT_PUBLIC_HOUSE_CKB_ADDRESS=ckt1...
# NEXT_PUBLIC_PLATFORM_CKB_ADDRESS=ckt1...
# NEXT_PUBLIC_CRASH_CASHOUT_FEE_BPS=300

# Pattern A — game-session-lock (same deployment as backend GAME_SESSION_LOCK_*)
# NEXT_PUBLIC_GAME_SESSION_LOCK_CODE_HASH=0x...
# NEXT_PUBLIC_GAME_SESSION_LOCK_HASH_TYPE=data1
# NEXT_PUBLIC_GAME_SESSION_LOCK_SCRIPT_CELL_DEP_TX_HASH=0x...
# NEXT_PUBLIC_GAME_SESSION_LOCK_SCRIPT_CELL_DEP_INDEX=0
# NEXT_PUBLIC_GAME_SESSION_LOCK_SCRIPT_CELL_DEP_TYPE=code
